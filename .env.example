# Gemini API Configuration
# Get your free key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Email Configuration (Sender Settings)
# For Gmail: SMTP Host is smtp.gmail.com, Port is 587
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_sender_gmail_address@gmail.com
# IMPORTANT: If using Gmail, this MUST be a 16-character App Password, NOT your regular password.
# How to get it: Google Account Security > 2-Step Verification > App Passwords.
EMAIL_PASS=your_gmail_app_password_here

# Recipient Configuration
EMAIL_TO=recipient_email_address@gmail.com
